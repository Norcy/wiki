<% if (post.date) { %>
    <div class="<%= class_name %>">
        <i class="fa fa-calendar"></i>
        <a href="<%- url_for(post.path) %>">
            <time datetime="<%= date_xml(post.created) %>" itemprop="datePublished"><%= date(post.created, date_format) %></time>
        </a>
    </div>
<% } %>
